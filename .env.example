# LAON SHOP 환경변수 예시 — 실제 값은 .env(커밋 금지)에 넣는다.

# PostgreSQL (Neon) — 두 URL은 서로 다른 호스트다:
#   DATABASE_URL = POOLED 엔드포인트(호스트에 "-pooler" 포함, 런타임/서버리스용)
#   DIRECT_URL   = DIRECT 엔드포인트("-pooler" 없음, prisma db push/migrate용)
# ※ Neon 무료 티어 콜드스타트 완화: connect_timeout / pool_timeout 파라미터 권장(첫 요청 웨이크업 지연 대비).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/DB?sslmode=require&channel_binding=require&connect_timeout=15&pool_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/DB?sslmode=require&channel_binding=require&connect_timeout=15"

# iron-session 시크릿 (32자 이상). openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string-min-32-chars"

# KSNET KSPAY — 테스트 MID 2999199999. 실 MID/키/API키는 KSNET 계약 후 설정.
PG_MODE="kspay"
KSPAY_STORE_ID="2999199999" # 카드사 심사용 개발계 MID. reHash 결박 규격 구현 전 실 MID로 교체 금지
# 아래 4종은 WEBFEP 수기·구인증 실연동 계약 후에만 설정. 원클릭 빌링은 별도 계약·안전 스펙 확정 전까지 비활성화.
# KSPAY_STORE_KEY=""      # 상점키 — 결제창 V1.4엔 미사용, KspayProvider/WEBFEP 계열에서 참조
# KSPAY_API_KEY=""        # WEBFEP REST 인증키(수기/구인증). 미설정 시 UI·서버 모두 비활성
# KSPAY_REST_LIVE="0"      # WEBFEP 실제 승인 차단 스위치. 계약·실 MID·API키 확인 후에만 1 (기본 비활성)
# KSPAY_WEBFEP_BASE=""    # WEBFEP base URL. 미설정 시 기본값 https://pay.ksnet.co.kr 사용

# 결제 콜백(rcv)/복귀 URL 구성용 절대 URL (배포 도메인). 로컬은 http://localhost:3003
SHOP_APP_URL="https://laonshop.com"
