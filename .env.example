# LAON SHOP 환경변수 예시 — 실제 값은 .env(커밋 금지)에 넣는다.

# PostgreSQL (Neon) — pooled(런타임) / direct(마이그레이션)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# iron-session 시크릿 (32자 이상). openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string-min-32-chars"

# KSNET KSPAY — 테스트 MID 2999199999 (상점키 불필요). 실 MID/키는 계약 후 교체.
PG_MODE="kspay"
KSPAY_STORE_ID="2999199999"
# KSPAY_STORE_KEY=""  # V1.4 결제창 방식엔 미사용

# 결제 콜백(rcv)/복귀 URL 구성용 절대 URL (배포 도메인). 로컬은 http://localhost:3003
SHOP_APP_URL="https://laonshop.com"
