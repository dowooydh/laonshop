// LAON SHOP — ㈜커스텀오더 의류 쇼핑몰 (KSNET 카드결제 카드사 심사용 + 실판매)
// 라온페이 모노레포 apps/shop에서 이관한 독립 스키마.

generator client {
  provider      = "prisma-client-js"
  // native = 로컬(mac)/빌드 OS, rhel-openssl-3.0.x = Vercel serverless(Node 20+) 런타임
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // 런타임: Neon pooled 연결
  directUrl = env("DIRECT_URL") // 마이그레이션/push: 직접 연결
}

model ShopUser {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  name         String
  phone        String?
  address      String? // 기본 배송지 (체크아웃 프리필 1순위)
  deletedAt    DateTime? // 탈퇴 (주문이력 보존 위해 소프트 삭제 — 전자상거래법 기록 보존)
  orders       ShopOrder[]
  wishlist     Wishlist[]
  createdAt    DateTime    @default(now())
}

// 위시리스트(찜) — 파생 데이터라 상품/회원 삭제 시 함께 정리 (재시드 FK 충돌 방지)
model Wishlist {
  id        String   @id @default(cuid())
  user      ShopUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Product {
  id          String          @id @default(cuid())
  name        String
  description String?
  price       Int // 원 단위 정수
  imageUrl    String?
  category    String? // 의류 카테고리 (상의/하의/신발)
  gender      String? // 성별 라인 (men/women)
  sizes       String? // 콤마구분 사이즈 (예: "S,M,L,XL")
  stock       Int             @default(999)
  active      Boolean         @default(true)
  sortOrder   Int             @default(0)
  orderItems  ShopOrderItem[]
  wishedBy    Wishlist[]
  createdAt   DateTime        @default(now())
}

enum ShopOrderStatus {
  PENDING // 결제대기
  PAID // 결제완료
  FAILED // 결제실패
  CANCEL_REQUESTED // 취소·반품 접수 (소비자 신청 — 운영자가 KSTA 수동취소 후 CANCELED 전환)
  CANCELED // 취소
}

model ShopOrder {
  id            String          @id @default(cuid())
  user          ShopUser        @relation(fields: [userId], references: [id])
  userId        String
  status        ShopOrderStatus @default(PENDING)
  totalAmount   Int
  moid          String          @unique // 주문번호 (KSPAY 결제 연동)
  approvalNo    String?
  pgTrno        String?
  cardName      String? // 발급 카드사명 (isscd 매핑 — 주문완료 결제수단 표기·심사 캡처용)
  paidAt        DateTime?
  receiverName  String?
  receiverPhone String?
  address       String?
  // 취소·반품 신청 (NEEDS_PG_SPEC: 카드 승인취소 API 미확보 — 신청 접수만 기록)
  cancelRequestedAt DateTime?
  cancelReason      String?
  items         ShopOrderItem[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId, createdAt])
}

model ShopOrderItem {
  id        String    @id @default(cuid())
  order     ShopOrder @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product   @relation(fields: [productId], references: [id])
  productId String
  name      String // 주문 시점 상품명 스냅샷
  price     Int // 주문 시점 단가
  qty       Int
  size      String? // 선택 사이즈

  @@index([orderId])
}
