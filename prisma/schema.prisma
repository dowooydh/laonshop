// LAON SHOP — ㈜커스텀오더 의류 쇼핑몰 (KSNET 카드결제 카드사 심사용 + 실판매)
// 라온페이 모노레포 apps/shop에서 이관한 독립 스키마.

generator client {
  provider      = "prisma-client-js"
  // native = 로컬(mac)/빌드 OS, rhel-openssl-3.0.x = Vercel serverless(Node 20+) 런타임
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // 런타임: Neon pooled 연결
  directUrl = env("DIRECT_URL") // 마이그레이션/push: 직접 연결
}

model ShopUser {
  id                    String                     @id @default(cuid())
  email                 String                     @unique
  passwordHash          String
  name                  String
  role                  ShopUserRole               @default(CUSTOMER)
  phone                 String?
  zipcode               String? // 우편번호 (다음 우편번호 검색)
  address               String? // 기본 배송지 — 도로명/지번 주소 (체크아웃 프리필 1순위)
  addressDetail         String? // 상세 주소 (동·호수 등 직접 입력)
  deletedAt             DateTime? // 탈퇴 (주문이력 보존 위해 소프트 삭제 — 전자상거래법 기록 보존)
  orders                ShopOrder[]
  wishlist              Wishlist[]
  billingCards          ShopBillingCard[]
  paymentMethods        ShopBillingPaymentMethod[]
  billingRegistrations  ShopBillingRegistration[]
  billingCharges        ShopBillingCharge[]
  billingCancelRequests ShopBillingCancelRequest[]
  auditLogs             ShopOrderAuditLog[]        @relation("ShopOrderAuditActor")
  createdAt             DateTime                   @default(now())
}

enum ShopUserRole {
  CUSTOMER
  ADMIN
}

// 과거 원클릭 mock 등록 레코드 — 신규 등록·결제에는 사용하지 않고 삭제만 허용한다.
// 과거 provider token 컬럼은 애플리케이션 스키마에서 제거했다. 운영 물리 컬럼 정리는
// 데이터 확인·백업 후 별도 승인된 cleanup으로만 수행한다.
model ShopBillingCard {
  id             String   @id @default(cuid())
  user           ShopUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  // 운영 물리 컬럼 정리 승인 전까지 schema drift/drop 대상에서 제외하되,
  // Prisma Client 애플리케이션 API에는 노출하지 않는다.
  billingToken   String   @unique @ignore
  maskedCardNumb String
  createdAt      DateTime @default(now())
}

enum ShopBillingPaymentMethodStatus {
  ACTIVE
  DEREGISTERING
  DEREGISTERED
  UNKNOWN
}

enum ShopBillingRegistrationStatus {
  REQUESTING
  PENDING
  PROCESSING
  SUCCEEDED
  DECLINED
  UNKNOWN
  EXPIRED
}

enum ShopBillingChargeStatus {
  REQUESTING
  PENDING
  PAID
  DECLINED
  UNKNOWN
  CANCEL_REQUESTED
  CANCELED
}

enum ShopBillingCancelRequestStatus {
  REQUESTING
  REQUESTED
  PROCESSING
  DONE
  REJECTED
  UNKNOWN
}

// LAONPAY가 보관한 KSNET billingToken을 가리키는 불투명 결제수단 원장.
// 카드 원문·provider token·PG 인증정보는 이 저장소와 DB에 절대 저장하지 않는다.
model ShopBillingPaymentMethod {
  id                        String                         @id @default(cuid())
  user                      ShopUser                       @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId                    String
  laonpayPaymentMethodId    String                         @unique
  cardName                  String
  cardLast4                 String
  cardType                  String
  status                    ShopBillingPaymentMethodStatus
  deregisterIdempotencyKey  String?                        @unique
  deregisterRequestAttempts Int                            @default(0)
  providerRegisteredAt      DateTime
  providerVerifiedAt        DateTime?
  providerDeregisteredAt    DateTime?
  registrations             ShopBillingRegistration[]
  charges                   ShopBillingCharge[]
  createdAt                 DateTime                       @default(now())
  updatedAt                 DateTime                       @updatedAt

  @@unique([id, userId])
  @@index([userId, status, createdAt])
}

// hosted 등록 시작 전에 로컬에서 멱등키를 선점한다. hostedUrl은 저장하지 않는다.
model ShopBillingRegistration {
  id                    String                        @id @default(cuid())
  user                  ShopUser                      @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId                String
  laonpayRegistrationId String?                       @unique
  idempotencyKey        String                        @unique
  requestFingerprint    String
  requestAttempts       Int                           @default(0)
  status                ShopBillingRegistrationStatus @default(REQUESTING)
  expiresAt             DateTime?
  paymentMethod         ShopBillingPaymentMethod?     @relation(fields: [paymentMethodId, userId], references: [id, userId], onDelete: Restrict)
  paymentMethodId       String?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt

  @@index([userId, status, createdAt])
}

// 주문당 외부 빌링 청구는 하나만 허용한다. UNKNOWN은 상태조회 전까지 새 결제를 차단한다.
model ShopBillingCharge {
  id                 String                    @id @default(cuid())
  user               ShopUser                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId             String
  order              ShopOrder                 @relation(fields: [orderId, userId], references: [id, userId], onDelete: Restrict)
  orderId            String                    @unique
  paymentMethod      ShopBillingPaymentMethod  @relation(fields: [paymentMethodId, userId], references: [id, userId], onDelete: Restrict)
  paymentMethodId    String
  laonpayChargeId    String?                   @unique
  idempotencyKey     String                    @unique
  requestFingerprint String
  requestAttempts    Int                       @default(0)
  amount             Int
  status             ShopBillingChargeStatus   @default(REQUESTING)
  providerPaymentId  String?                   @unique
  failureCode        String?
  cancelRequest      ShopBillingCancelRequest?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@unique([id, userId])
  @@unique([orderId, userId])
  @@index([userId, status, createdAt])
  @@index([paymentMethodId, status])
}

// 부분취소 없이 주문당 한 번의 전체취소 요청만 기록한다. 실제 PG 취소는 LAONPAY 관리자에서 수행한다.
model ShopBillingCancelRequest {
  id                     String                         @id @default(cuid())
  user                   ShopUser                       @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId                 String
  charge                 ShopBillingCharge              @relation(fields: [chargeId, userId], references: [id, userId], onDelete: Restrict)
  chargeId               String                         @unique
  laonpayCancelRequestId String?                        @unique
  idempotencyKey         String                         @unique
  reason                 String?
  rejectReason           String?
  requestSentAt          DateTime?
  providerProcessedAt    DateTime?
  status                 ShopBillingCancelRequestStatus @default(REQUESTING)
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt

  @@unique([chargeId, userId])
  @@index([userId, status, createdAt])
}

// 위시리스트(찜) — 파생 데이터라 상품/회원 삭제 시 함께 정리 (재시드 FK 충돌 방지)
model Wishlist {
  id        String   @id @default(cuid())
  user      ShopUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Product {
  id          String          @id @default(cuid())
  name        String
  description String?
  price       Int // 원 단위 정수
  imageUrl    String?
  category    String? // 의류 카테고리 (상의/하의/신발)
  gender      String? // 성별 라인 (men/women)
  sizes       String? // 콤마구분 사이즈 (예: "S,M,L,XL")
  stock       Int             @default(999)
  active      Boolean         @default(true)
  sortOrder   Int             @default(0)
  orderItems  ShopOrderItem[]
  wishedBy    Wishlist[]
  createdAt   DateTime        @default(now())
}

enum ShopOrderStatus {
  PENDING // 결제대기
  PAID // 결제완료
  FAILED // 결제실패
  CANCEL_REQUESTED // 취소·반품 접수 (소비자 신청 — 운영자가 KSTA 수동취소 후 CANCELED 전환)
  CANCELED // 취소
}

enum ShopOrderAuditAction {
  PAYMENT_CONFIRMED_PAID
  PAYMENT_CONFIRMED_FAILED
}

model ShopOrder {
  id                String              @id @default(cuid())
  user              ShopUser            @relation(fields: [userId], references: [id])
  userId            String
  status            ShopOrderStatus     @default(PENDING)
  totalAmount       Int
  moid              String              @unique // 주문번호 (KSPAY 결제 연동)
  approvalNo        String?
  pgTrno            String?             @unique
  cardName          String? // 발급 카드사명 (isscd 매핑 — 주문완료 결제수단 표기·심사 캡처용)
  paidAt            DateTime?
  receiverName      String?
  receiverPhone     String?
  address           String?
  // 취소·반품 신청 (NEEDS_PG_SPEC: 카드 승인취소 API 미확보 — 신청 접수만 기록)
  cancelRequestedAt DateTime?
  cancelReason      String?
  items             ShopOrderItem[]
  auditLogs         ShopOrderAuditLog[]
  billingCharge     ShopBillingCharge?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([id, userId])
  @@index([userId, createdAt])
  @@index([status, approvalNo, updatedAt])
}

model ShopOrderItem {
  id        String    @id @default(cuid())
  order     ShopOrder @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product   @relation(fields: [productId], references: [id])
  productId String
  name      String // 주문 시점 상품명 스냅샷
  price     Int // 주문 시점 단가
  qty       Int
  size      String? // 선택 사이즈

  @@index([orderId])
}

// 결제 결과가 불명확한 주문을 운영자가 KSTA에서 대조해 확정한 이력.
// 주문 상태 변경과 같은 트랜잭션에서만 append하며 수정·삭제 UI는 제공하지 않는다.
model ShopOrderAuditLog {
  id              String               @id @default(cuid())
  order           ShopOrder            @relation(fields: [orderId], references: [id], onDelete: Restrict)
  orderId         String
  actor           ShopUser             @relation("ShopOrderAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  actorUserId     String
  actorEmail      String // 처리 당시 관리자 이메일 스냅샷
  action          ShopOrderAuditAction
  fromStatus      ShopOrderStatus
  toStatus        ShopOrderStatus
  reason          String
  confirmedAmount Int?
  approvalNo      String?
  pgTrno          String?
  cardName        String?
  createdAt       DateTime             @default(now())

  @@index([orderId, createdAt])
  @@index([actorUserId, createdAt])
}
